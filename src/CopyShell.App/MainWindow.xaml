<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CopyShell.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0">
            <StackPanel Padding="28" Spacing="14">
                <TextBlock
                    x:Name="OperationTitle"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Text="高级复制到…" />
                <TextBlock
                    x:Name="OperationDescription"
                    Text="使用 Robocopy 可靠地处理所选项目。" />

                <InfoBar
                    x:Name="StartupInfo"
                    IsClosable="False"
                    IsOpen="False" />
                <InfoBar
                    x:Name="SyncWarning"
                    IsClosable="False"
                    IsOpen="False" />

                <TextBlock FontWeight="SemiBold" Text="源项目" />
                <ListView
                    x:Name="SourceList"
                    MinHeight="100"
                    SelectionMode="None" />

                <TextBlock FontWeight="SemiBold" Text="目标文件夹" />
                <TextBox
                    x:Name="DestinationBox"
                    PlaceholderText="选择目标文件夹" />
                <Button
                    Click="OnBrowseClicked"
                    Content="浏览…" />

                <TextBlock FontWeight="SemiBold" Text="高级选项" />
                <ComboBox
                    x:Name="ConflictStrategyBox"
                    Header="文件冲突处理"
                    SelectedIndex="0">
                    <ComboBoxItem Content="覆盖不同的目标文件" />
                    <ComboBoxItem Content="跳过所有已存在文件" />
                    <ComboBoxItem Content="仅复制较新的文件" />
                </ComboBox>
                <NumberBox
                    x:Name="ThreadCountBox"
                    Header="并行线程数"
                    Maximum="128"
                    Minimum="1"
                    Value="16" />
                <NumberBox
                    x:Name="RetryCountBox"
                    Header="失败重试次数"
                    Maximum="100"
                    Minimum="0"
                    Value="2" />
                <CheckBox
                    x:Name="RestartableCheckBox"
                    IsChecked="True"
                    Content="断点续传（/Z）" />
                <CheckBox
                    x:Name="ExcludeJunctionsCheckBox"
                    IsChecked="True"
                    Content="跳过目录联接（/XJ）" />

                <StackPanel
                    x:Name="ProgressArea"
                    Spacing="8"
                    Visibility="Collapsed">
                    <ProgressBar
                        x:Name="TaskProgress"
                        IsIndeterminate="True" />
                    <TextBlock
                        x:Name="StatusText"
                        Text="准备中…" />
                    <TextBlock
                        x:Name="ProgressDetailsText"
                        Visibility="Collapsed" />
                </StackPanel>

                <Expander
                    x:Name="LogExpander"
                    Header="执行日志"
                    Visibility="Collapsed">
                    <TextBox
                        x:Name="LogBox"
                        AcceptsReturn="True"
                        IsReadOnly="True" />
                </Expander>

                <TextBlock FontWeight="SemiBold" Text="任务队列与历史" />
                <Button
                    Click="OnRefreshQueueClicked"
                    Content="刷新" />
                <ListView
                    x:Name="QueueList"
                    MinHeight="140"
                    SelectionMode="Single" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        x:Name="PauseQueueButton"
                        Click="OnPauseQueueClicked"
                        Content="暂停"
                        IsEnabled="False" />
                    <Button
                        x:Name="ResumeQueueButton"
                        Click="OnResumeQueueClicked"
                        Content="恢复"
                        IsEnabled="False" />
                    <Button
                        x:Name="RetryQueueButton"
                        Click="OnRetryQueueClicked"
                        Content="重试任务"
                        IsEnabled="False" />
                    <Button
                        x:Name="CancelQueueButton"
                        Click="OnCancelQueueClicked"
                        Content="取消任务"
                        IsEnabled="False" />
                </StackPanel>
                <TextBox
                    x:Name="QueueDetailsBox"
                    AcceptsReturn="True"
                    IsReadOnly="True"
                    TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1">
            <Button
                x:Name="CancelButton"
                HorizontalAlignment="Left"
                Click="OnCancelClicked"
                Content="取消"
                IsEnabled="False" />
            <Button
                x:Name="StartButton"
                HorizontalAlignment="Right"
                Click="OnStartClicked"
                Content="开始复制"
                IsEnabled="False" />
        </Grid>
    </Grid>
</Window>
