<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CopyShell.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        x:Name="RootGrid"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="28,24,28,18" Spacing="5">
            <TextBlock
                x:Name="OperationTitle"
                FontSize="28"
                FontWeight="SemiBold"
                Text="高级复制到…" />
            <TextBlock
                x:Name="OperationDescription"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="使用 Robocopy 可靠地处理所选项目。" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="28,12,28,22" Spacing="18">
                <InfoBar
                    x:Name="StartupInfo"
                    IsClosable="False"
                    IsOpen="False"
                    Severity="Error"
                    Title="无法创建任务" />

                <InfoBar
                    x:Name="SyncWarning"
                    IsClosable="False"
                    IsOpen="False"
                    Severity="Warning"
                    Title="镜像同步可能删除目标文件"
                    Message="目标中源端不存在的项目会被删除，开始前将再次确认。" />

                <StackPanel Spacing="8">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="源项目" />
                    <Border
                        MinHeight="110"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <ListView
                            x:Name="SourceList"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Padding="8,5"
                                        Text="{Binding}"
                                        TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="目标文件夹" />
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="DestinationBox"
                            Grid.Column="0"
                            PlaceholderText="选择目标文件夹"
                            TextChanged="OnDestinationChanged" />
                        <Button
                            Grid.Column="1"
                            Click="OnBrowseClicked"
                            Content="浏览…" />
                    </Grid>
                </StackPanel>

                <Expander Header="高级选项">
                    <Grid Padding="0,12,0,4" ColumnSpacing="18" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ComboBox
                            x:Name="ConflictStrategyBox"
                            Grid.Row="0"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Header="文件冲突处理"
                            SelectedIndex="0">
                            <ComboBoxItem Content="覆盖不同的目标文件" />
                            <ComboBoxItem Content="跳过所有已存在文件" />
                            <ComboBoxItem Content="仅复制较新的文件" />
                        </ComboBox>
                        <NumberBox
                            x:Name="ThreadCountBox"
                            Grid.Row="1"
                            Grid.Column="0"
                            Header="并行线程数"
                            Maximum="128"
                            Minimum="1"
                            SpinButtonPlacementMode="Compact"
                            Value="16" />
                        <NumberBox
                            x:Name="RetryCountBox"
                            Grid.Row="1"
                            Grid.Column="1"
                            Header="失败重试次数"
                            Maximum="100"
                            Minimum="0"
                            SpinButtonPlacementMode="Compact"
                            Value="2" />
                        <CheckBox
                            x:Name="RestartableCheckBox"
                            Grid.Row="2"
                            Grid.Column="0"
                            IsChecked="True"
                            Content="断点续传（/Z）" />
                        <CheckBox
                            x:Name="ExcludeJunctionsCheckBox"
                            Grid.Row="2"
                            Grid.Column="1"
                            IsChecked="True"
                            Content="跳过目录联接（/XJ）" />
                    </Grid>
                </Expander>

                <StackPanel x:Name="ProgressArea" Spacing="8" Visibility="Collapsed">
                    <ProgressBar x:Name="TaskProgress" IsIndeterminate="True" />
                    <TextBlock
                        x:Name="StatusText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="准备中…" />
                    <TextBlock
                        x:Name="ProgressDetailsText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text=""
                        Visibility="Collapsed" />
                </StackPanel>

                <Expander
                    x:Name="LogExpander"
                    Header="执行日志"
                    Visibility="Collapsed">
                    <TextBox
                        x:Name="LogBox"
                        MinHeight="180"
                        MaxHeight="300"
                        Padding="10"
                        AcceptsReturn="True"
                        FontFamily="Consolas"
                        FontSize="12"
                        IsReadOnly="True"
                        TextWrapping="NoWrap" />
                </Expander>

                <StackPanel Spacing="10">
                    <Grid>
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="任务队列与历史" />
                        <Button
                            HorizontalAlignment="Right"
                            Click="OnRefreshQueueClicked"
                            Content="刷新" />
                    </Grid>

                    <ListView
                        x:Name="QueueList"
                        MinHeight="150"
                        MaxHeight="290"
                        SelectionChanged="OnQueueSelectionChanged"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="6,5" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock
                                            FontWeight="SemiBold"
                                            Text="{Binding Title}" />
                                        <TextBlock
                                            MaxWidth="510"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding Route}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding ProgressText}" />
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Text="{Binding StateText}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            x:Name="PauseQueueButton"
                            Click="OnPauseQueueClicked"
                            Content="暂停"
                            IsEnabled="False" />
                        <Button
                            x:Name="ResumeQueueButton"
                            Click="OnResumeQueueClicked"
                            Content="恢复"
                            IsEnabled="False" />
                        <Button
                            x:Name="RetryQueueButton"
                            Click="OnRetryQueueClicked"
                            Content="重试任务"
                            IsEnabled="False" />
                        <Button
                            x:Name="CancelQueueButton"
                            Click="OnCancelQueueClicked"
                            Content="取消任务"
                            IsEnabled="False" />
                    </StackPanel>

                    <TextBox
                        x:Name="QueueDetailsBox"
                        MinHeight="70"
                        MaxHeight="150"
                        AcceptsReturn="True"
                        IsReadOnly="True"
                        PlaceholderText="选择任务查看来源、目标、失败摘要和日志"
                        TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Padding="28,14">
            <Button
                x:Name="CancelButton"
                HorizontalAlignment="Left"
                Click="OnCancelClicked"
                Content="取消"
                IsEnabled="False" />
            <Button
                x:Name="StartButton"
                HorizontalAlignment="Right"
                Click="OnStartClicked"
                Content="开始复制"
                IsEnabled="False"
                Style="{StaticResource AccentButtonStyle}" />
        </Grid>
    </Grid>
</Window>
